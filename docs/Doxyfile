# Doxyfile for libstp C++ documentation

PROJECT_NAME           = "libstp"
PROJECT_BRIEF          = "Robotics library for Botball"
OUTPUT_DIRECTORY       = _build/doxygen

# Input sources
INPUT                  = ../modules
FILE_PATTERNS          = *.hpp *.h
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */bindings/*

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# Build options
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# HTML options
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Graphs (requires graphviz)
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
